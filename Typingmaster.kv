<Root>:
    orientation: "vertical"
    padding: 15
    spacing: 10

    Label:
        text: "TYPING MASTER PRO"
        font_size: 28

    Label:
        text: root.highscore_text
        size_hint_y: None
        height: 40

    TextInput:
        id: name_input
        hint_text: "Enter Name"
        multiline: False
        size_hint_y: None
        height: 50

    Button:
        text: "Start Test"
        size_hint_y: None
        height: 55
        on_press: root.start_test()

    Label:
        text: root.sentence
        text_size: self.width, None

    TextInput:
        id: typing_input
        hint_text: "Type sentence here..."
        multiline: True

    Button:
        text: "Submit"
        size_hint_y: None
        height: 55
        on_press: root.submit_test()

    Label:
        text: root.result
        text_size: self.width, None
